coding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="64"/><column index="3" value="86"/><column index="4" value="39"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="schedules" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="68"/><column index="3" value="58"/><column index="4" value="67"/><column index="5" value="61"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT * FROM courses;
SELECT * FROM course_sections;
SELECT * FROM enrollments;
SELECT
    s.student_code,
    s.full_name,
    c.course_name,
    cs.section_name
FROM enrollments e
JOIN students s
    ON e.student_id = s.id
JOIN course_sections cs
    ON e.section_id = cs.id
JOIN courses c
    ON cs.course_id = c.id;
	
SELECT name
FROM sqlite_master
WHERE type='table';

CREATE TABLE schedules (
    id INTEGER PRIMARY KEY AUTOINCREMENT,

    section_id INTEGER NOT NULL,

    weekday INTEGER NOT NULL,

    start_time TEXT NOT NULL,

    end_time TEXT NOT NULL,

    FOREIGN KEY(section_id)
        REFERENCES course_sections(id)
);

INSERT INTO schedules
(
    section_id,
    weekday,
    start_time,
    end_time
)
VALUES
(
    1,
    0,
    '06:45',
    '09:25'
);


INSERT INTO schedules
(
    section_id,
    weekday,
    start_time,
    end_time
)
VALUES
(
    2,
    0,
    '13:00',
    '15:45'
);

SELECT * FROM schedules;

UPDATE schedules
SET start_time='14:00',
    end_time='15:00'
WHERE id=1;

SELECT *
FROM attendance_sessions
ORDER BY id DESC;

SELECT
    id,
    section_id,
    session_date,
    is_active
FROM attendance_sessions
ORDER BY id DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
